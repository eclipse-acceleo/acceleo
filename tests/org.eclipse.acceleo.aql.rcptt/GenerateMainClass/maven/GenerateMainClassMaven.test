with [get-view "Package Explorer" | get-tree] {
    select "test/src\\/main\\/java/test/test.mtl" | get-menu -path "Initialize Generator Launcher/Java Main Class" | click 
        -metaKeys ""
}
with [get-window "Generation comparison"] {
    get-tree | select "test/pom.xml" | double-click
    get-button "Next Difference" | click -metaKeys ""
    get-button "Copy Current Change from Left to Right" | click -metaKeys ""
    get-button Commit | click -metaKeys ""
}
with [get-view "Package Explorer" | get-tree] {
    select "test/src\\/main\\/java/test/TestGenerator.java-expected.txt" "test/src\\/main\\/java/test/TestGenerator.java"
    get-menu -path "Compare With/Each Other" | click -metaKeys ""
}
get-label "Left: 1 : 1, Right: 1 : 1, no diff" | get-property caption | equals "Left: 1 : 1, Right: 1 : 1, no diff" 
    | verify-true
get-view "Package Explorer" | click
get-editor "Compare ('test/src/main/java/test/TestGenerator.java' - 'test/src/main/java/test/TestGenerator.java-expected.txt')" 
    | close
