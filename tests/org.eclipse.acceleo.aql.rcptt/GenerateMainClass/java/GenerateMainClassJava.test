with [get-view "Package Explorer" | get-tree] {
    select "test/src/test/test.mtl" | get-menu -path "Initialize Generator Launcher/Java Main Class" | click 
        -metaKeys ""
}
with [get-view "Package Explorer" | get-tree] {
    select "test/src/test/TestGenerator.java-expected.txt" "test/src/test/TestGenerator.java"
    get-menu -path "Compare With/Each Other" | click -metaKeys ""
}
get-label "Left: 1 : 1, Right: 1 : 1, no diff" | get-property caption | equals "Left: 1 : 1, Right: 1 : 1, no diff" 
    | verify-true

get-editor "Compare ('test/src/test/TestGenerator.java' - 'test/src/test/TestGenerator.java-expected.txt')" | close
get-view "Package Explorer" | get-tree | select "test/src/test/TestGenerator.java" 
    | select "test/src/test/TestGenerator.java" | get-menu -path "Open With/Text Editor" | click -metaKeys ""
with [get-editor "TestGenerator.java" | get-text-viewer] {
    hover-text 57 16
    select-range 60 26 60 27
    type-text r2
    key-type "M1+s"
}
get-view "Package Explorer" | get-tree | select "test/src/test/test.mtl" | get-menu 
    -path "Initialize Generator Launcher/Java Main Class" | click -metaKeys ""
with [get-window "Generation comparison"] {
    get-tree | select "test/src/test/TestGenerator.java" | double-click
}
with [get-window "Generation comparison"] {
    get-button "Copy Current Change from Left to Right" | click -metaKeys ""
    get-button Commit | click -metaKeys ""
}
with [get-view "Package Explorer" | get-tree] {
    select "test/src/test/TestGenerator.java-expected.txt" "test/src/test/TestGenerator.java"
    get-menu -path "Compare With/Each Other" | click -metaKeys ""
}
get-label "Left: 1 : 1, Right: 1 : 1, no diff" | get-property caption | equals "Left: 1 : 1, Right: 1 : 1, no diff" 
    | verify-true
get-editor "TestGenerator.java" | click
get-editor "Compare ('test/src/test/TestGenerator.java' - 'test/src/test/TestGenerator.java-expected.txt')" | close
get-view "Package Explorer" | click
get-editor "TestGenerator.java" | close
